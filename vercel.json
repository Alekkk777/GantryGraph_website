{
  "buildCommand": "pip install --break-system-packages -r requirements.txt && pip install --break-system-packages \"git+https://github.com/GantryGraph/GantryGraph.git\" && python -m mkdocs build",
  "outputDirectory": "site",
  "framework": null,
  "installCommand": "pip install --break-system-packages -r requirements.txt",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/docs/(.*)", "destination": "/$1" }
  ]
}
